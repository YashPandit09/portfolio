# Copy to .env.local and fill in your values.

# EmailJS — contact form delivery (https://dashboard.emailjs.com/admin)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
# Private key (Account -> General -> API keys). Required for server-side sends.
EMAILJS_PRIVATE_KEY=

# Cloudflare Turnstile — anti-spam (https://dash.cloudflare.com -> Turnstile)
# Leave blank to disable the captcha (honeypot still applies).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
